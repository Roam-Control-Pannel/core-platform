# ============================================================================
# Roam — environment template
#
# Copy to `.env` and fill in. NEVER commit `.env` (it's gitignored).
#
# CRITICAL — PROJECT ISOLATION:
# Every value below comes from the ROAM org's RoamLocal Core Project ONLY:
#   Supabase org : Roam-Core-Platform   (NOT "Roam Agency - DDS")
#   Project      : RoamLocal Core Project
#   Project ref  : kyancopdkxotzzkzqsmf
#
# Do NOT paste any key from DDS or the Roam CRM here. If a value's dashboard
# tab says "Direct Desk Solutions" anywhere, it's the wrong key — stop.
# ============================================================================

# --- Supabase: public (safe to expose to browser/native bundles) ------------
# Dashboard → Project Settings → API
# URL looks like https://kyancopdkxotzzkzqsmf.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: SECRET (server-only, NEVER in any client bundle) -------------
# Dashboard → Project Settings → API → service_role key.
# This bypasses RLS. Used only by Edge Functions / webhooks / cron.
# If this ever appears in apps/web, apps/console, or apps/native client code,
# that is a security incident — it belongs to server contexts exclusively.
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-to-server auth (the x-internal-call pattern from Roam CRM) ------
# A long random secret. Generate fresh for ROAM — do not reuse the CRM's.
#   openssl rand -hex 32
INTERNAL_CALL_SECRET=

# --- Stripe (LATER — billing slice). Roam's OWN Stripe setup. ---------------
# Leave blank until we wire billing. When we do: Roam-specific keys + webhook,
# never DDS's live Stripe. A Roam webhook must never touch DDS orders.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary (LATER — media). Roam's own cloud/folder. -------------------
# CLOUDINARY_URL=

# --- Maps / Places (LATER — discovery). Global venue base layer. ------------
# GOOGLE_PLACES_API_KEY=
# NEXT_PUBLIC_MAP_SDK_KEY=
