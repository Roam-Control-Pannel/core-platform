# ============================================================================
# Roam — environment template
#
# Copy to `.env` and fill in. NEVER commit `.env` (it's gitignored).
#
# CRITICAL — PROJECT ISOLATION:
# Every value below comes from the ROAM org's RoamLocal Core Project ONLY:
#   Supabase org : Roam-Core-Platform   (NOT "Roam Agency - DDS")
#   Project      : RoamLocal Core Project
#   Project ref  : kyancopdkxotzzkzqsmf
#
# Do NOT paste any key from DDS or the Roam CRM here. If a value's dashboard
# tab says "Direct Desk Solutions" anywhere, it's the wrong key — stop.
# ============================================================================

# --- Supabase: public (safe to expose to browser/native bundles) ------------
# Dashboard → Project Settings → API
# Use the project's CUSTOM DOMAIN once active (branded auth links + same-origin
# trust): https://auth.roam-local.com. The raw https://<ref>.supabase.co URL also
# works, but we standardised on the custom domain for app + email links.
NEXT_PUBLIC_SUPABASE_URL=https://auth.roam-local.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Social sign-in (SSO) toggles ------------------------------------------
# Each provider's "Continue with …" button only renders when its flag is "1" — so a button
# never appears before the provider is actually configured in Supabase (Auth → Providers).
# Build-time (NEXT_PUBLIC_), so flipping one needs a redeploy. Google is free to enable;
# Apple needs the Apple Developer Program. See docs/SSO_SETUP.md.
# NEXT_PUBLIC_ENABLE_GOOGLE_SSO=1
# NEXT_PUBLIC_ENABLE_APPLE_SSO=1

# --- Supabase: SECRET (server-only, NEVER in any client bundle) -------------
# Dashboard → Project Settings → API → service_role key.
# This bypasses RLS. Used only by Edge Functions / webhooks / cron.
# If this ever appears in apps/web, apps/console, or apps/native client code,
# that is a security incident — it belongs to server contexts exclusively.
SUPABASE_SERVICE_ROLE_KEY=

# --- Server-to-server auth (the x-internal-call pattern from Roam CRM) ------
# A long random secret. Generate fresh for ROAM — do not reuse the CRM's.
#   openssl rand -hex 32
INTERNAL_CALL_SECRET=

# --- Web Push (VAPID). Follower push notifications. -------------------------
# Generate ONCE with: npx web-push generate-vapid-keys
# The PUBLIC key is browser-safe (it becomes the applicationServerKey); it is
# prefixed NEXT_PUBLIC_ so sync-env.mjs inlines it into the web bundle.
# The PRIVATE key is a SERVER-ONLY secret — it signs push payloads at dispatch.
# It is UNPREFIXED so it is never copied into any client bundle. Treat it like
# the service-role key: if it appears in apps/web|console|native, that's an incident.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Web Push (VAPID). Follower push notifications. -------------------------
# Generate ONCE with: npx web-push generate-vapid-keys
# The PUBLIC key is browser-safe (it becomes the applicationServerKey); it is
# prefixed NEXT_PUBLIC_ so sync-env.mjs inlines it into the web bundle.
# The PRIVATE key is a SERVER-ONLY secret — it signs push payloads at dispatch.
# It is UNPREFIXED so it is never copied into any client bundle. Treat it like
# the service-role key: if it appears in apps/web|console|native, that's an incident.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Stripe (LATER — billing slice). Roam's OWN Stripe setup. ---------------
# Leave blank until we wire billing. When we do: Roam-specific keys + webhook,
# never DDS's live Stripe. A Roam webhook must never touch DDS orders.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Cloudinary (LATER — media). Roam's own cloud/folder. -------------------
# CLOUDINARY_URL=

# --- Maps / Places (LATER — discovery). Global venue base layer. ------------
GOOGLE_PLACES_API_KEY_CORE=
# NEXT_PUBLIC_MAP_SDK_KEY=

# --- Awin affiliate (Deals surface). ----------------------------------------
# The publisher id (awinaffid) is PUBLIC — it appears in every affiliate link — so it's
# NEXT_PUBLIC_ and inlined into the web bundle. Deals links stay untracked (plain outbound)
# until this is set; set it in the Vercel/Netlify web project env.
# NEXT_PUBLIC_AWIN_PUBLISHER_ID=
# The Awin Offers API OAuth token (server-only, on the API/Railway) — used by the deals
# ingestion in a later PR. Keep it OUT of the web bundle and out of git.
# AWIN_API_TOKEN=

# --- Brevo marketing-list sync (API service). Optional: unset = sync is a no-op. -
# BREVO_API_KEY is a v3 API key (NOT the SMTP key) — server-only, on the API (Railway).
# New users join BREVO_LIST_NEW_USERS; approved business owners join BREVO_LIST_BUSINESSES.
# BREVO_API_KEY=
# BREVO_LIST_NEW_USERS=93
# BREVO_LIST_BUSINESSES=3
# Shared secret the Supabase "profiles INSERT" Database Webhook sends as the
# `x-webhook-secret` header; the web /api/brevo/contact-created route validates it. Set on web.
# BREVO_WEBHOOK_SECRET=

# --- Translink Opendata (Northern Ireland live transit — API service) -------
# Server-only, on the API (Railway). Unset = the NI "Nearby departures" feature is dormant
# (transit.nearbyDepartures returns status "unconfigured"); the API still boots.
# The key is the ONLY required value. How it rides on each request is Translink-specific, and the
# client AUTO-DETECTS it: it tries the primary mode, falls back to the other on an auth rejection,
# then pins + logs whichever Translink accepts (look for "[transit] EFA auth accepted"). Once the
# logs reveal the answer, set TRANSLINK_AUTH_MODE explicitly to skip the probe.
#   TRANSLINK_AUTH_MODE=query   (default) → appended as ?<param>=<key>; param name TRANSLINK_AUTH_PARAM (default "key")
#   TRANSLINK_AUTH_MODE=header             → sent as header <name>: <key>;  header name TRANSLINK_AUTH_HEADER (default "Authorization")
# TRANSLINK_API_BASE overrides the EFA base URL (default the documented http Ext_API endpoint).
# TRANSLINK_DEBUG=1 logs the raw (truncated) EFA JSON + the resolved board — set it for the first
# live verification, then unset it.
# Translink authorizes access by SERVER IP (the API is keyless). Railway's egress IP rotates
# within a /23 pool, so route the calls through a STATIC-IP forward proxy (QuotaGuard Static /
# Fixie) and register the proxy's fixed IP with Translink. Unset = calls go out directly.
# TRANSLINK_API_KEY=
# TRANSLINK_API_BASE=https://opendata.translinkniplanner.co.uk/Ext_API/
# TRANSLINK_PROXY_URL=http://user:pass@static-proxy.example.com:9293
# TRANSLINK_DEBUG=1

# --- Roam API service (the standalone tRPC service — Shape B) ---------------
# Where web/console/native send tRPC calls; the client appends "/trpc".
# Set the ORIGIN only. local dev example: http://localhost:8787
NEXT_PUBLIC_API_URL=

# --- Public site origin (SEO: canonical URLs, Open Graph, sitemap, robots) ---
# The site's canonical PRODUCTION origin, NO trailing slash. Used to build every
# absolute URL: <link rel="canonical">, og:image, sitemap.xml and robots.txt.
# If unset it falls back to http://localhost:3000 — so it MUST be set in the
# production deploy env (Vercel) or live pages advertise localhost to crawlers.
# Pick ONE canonical host (apex OR www) and keep it consistent. local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://www.roam-local.com

# --- Google Search Console verification (OPTIONAL) --------------------------
# Only needed for the HTML meta-tag verification method — a DNS "Domain" property
# (the recommended route) needs nothing here. Paste the token from Google's
# <meta name="google-site-verification" content="..."> tag; layout.tsx emits it.
GOOGLE_SITE_VERIFICATION=

# --- Supabase: API-service names (server.ts reads these UNPREFIXED) ----------
# Same values as NEXT_PUBLIC_SUPABASE_* above, under the names the API service
# reads at boot (it is not a Next app, so no NEXT_PUBLIC_ prefix). Use the same
# custom domain: https://auth.roam-local.com.
SUPABASE_URL=https://auth.roam-local.com
SUPABASE_ANON_KEY=
