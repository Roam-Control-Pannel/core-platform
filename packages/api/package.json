{
  "name": "@roam/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./trpc": "./src/trpc.ts",
    "./context": "./src/context.ts",
    "./routers": "./src/routers/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/dev.ts",
    "start": "tsx src/main.ts",
    "backfill:photos": "tsx --env-file=../../.env scripts/backfill-photos.ts",
    "deliver-birthdays": "tsx src/jobs/deliverBirthdays.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@roam/core": "workspace:*",
    "@roam/db": "workspace:*",
    "@supabase/supabase-js": "2.106.2",
    "@trpc/server": "^11.0.0",
    "undici": "^6.27.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@roam/eslint-config": "workspace:*",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^3.2.0"
  }
}
